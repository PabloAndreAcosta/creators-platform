# ===========================================
# Creators Platform - Environment Variables
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (6 role-based plans)
STRIPE_PUBLIK_GULD_PRICE_ID=price_xxx
STRIPE_PUBLIK_PREMIUM_PRICE_ID=price_xxx
STRIPE_KREATOR_GULD_PRICE_ID=price_xxx
STRIPE_KREATOR_PREMIUM_PRICE_ID=price_xxx
STRIPE_UPPLEVELSE_GULD_PRICE_ID=price_xxx
STRIPE_UPPLEVELSE_PREMIUM_PRICE_ID=price_xxx

# Facebook (for Events two-way sync)
# Create an app at https://developers.facebook.com/
# Required permissions: pages_manage_metadata, pages_manage_events, pages_read_user_content
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Instagram (Instagram Business Login via Meta app)
# Configure at https://developers.facebook.com/ under your app's Instagram settings
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://usha.se/api/instagram/callback

# TikTok (Content Display API)
# Create an app at https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Signicat (BankID verification for creators/experiences)
# Get credentials at https://dashboard.signicat.com/
SIGNICAT_CLIENT_ID=your_signicat_client_id
SIGNICAT_CLIENT_SECRET=your_signicat_client_secret
SIGNICAT_ACCOUNT_ID=your_signicat_account_id
SIGNICAT_API_BASE=https://api.signicat.com
BANKID_COOKIE_SECRET=generate_a_random_32_char_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Beta mode — set to "true" to unlock all features for all users (no paywalls)
NEXT_PUBLIC_BETA_MODE=true
